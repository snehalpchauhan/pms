# Copy to deploy.local.env (gitignored) and fill in real values:
#   cp scripts/deploy.local.env.example scripts/deploy.local.env
#
# deploy.sh defaults (override only if needed):
#   DEPLOY_HOST=root@72.61.227.155
#   DEPLOY_PATH=/var/www/pms
#   DEPLOY_BRANCH=main
#   DEPLOY_SERVICE=pms.service
#
# --- SSH authentication (use one approach) ---
#
# A) Password for the SSH user (e.g. Linux root on VPS). Requires sshpass:
#    macOS:  brew install hudochenkov/sshpass/sshpass
#    Debian: sudo apt install sshpass
# export DEPLOY_SSH_PASSWORD='your-ssh-user-password'
#
# B) Private key file (recommended). Public key must be in the user's
#    ~/.ssh/authorized_keys on the server (Hostinger: VPS → SSH keys / console).
# export DEPLOY_SSH_KEY="$HOME/.ssh/id_ed25519"
#
# C) Optional overrides:
# export DEPLOY_HOST='root@YOUR_VPS_IP'
# export DEPLOY_PATH='/var/www/pms'
